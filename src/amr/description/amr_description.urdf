  <robot name="amr">

    <material name= "white">
      <color rgba="1 1 1 1" />
    </material>

    <material name= "orange">
      <color rgba="1 0.3 0.1 1" />
    </material>

    <material name= "blue">
      <color rgba="0.2 0.2 1 1" />
    </material>

    <material name= "black">
      <color rgba="0 0 0 1" />
    </material>

    <material name= "red">
      <color rgba="1 0 0 1" />
    </material>


    <!-- Base Footprint -->
    <link name="base_link"/>

    <!-- Base Link -->
    <link name="chassis">
      <visual name="base_visual">
        <origin xyz="0 0 0.28" rpy="0 0 0"/>
        <geometry>
          <box size="0.5 0.42 0.52"/>
          <!-- <box size="0.45 0.72 0.61"/>-->
        </geometry>
        <material name="white"/>
      </visual>
    </link>

    <link name="laser">
      <visual name="laser_visual">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.0385" length="0.03885"/>
        </geometry>
        <material name="black"/>
      </visual>
    </link>

    <link name="lidar2_link">
      <visual name="lidar2_visual">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.0385" length="0.03885"/>
        </geometry>
        <material name="black"/>
      </visual>
    </link>

    <link name="lidar1_link">
      <visual name="lidar1_visual">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.0385" length="0.03885"/>
        </geometry>
          <material name="black"/>
      </visual>
    </link>

    <link name="imu_link">
      <visual name="imu_visual">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.04 0.03 0.01"/>
        </geometry>
        <material name="blue"/>
      </visual>
    </link>


    <!-- Left Wheel Link -->
    <link name="wheel_left_link">
      <collision name="wheel_left_collision">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0" length="0.046"/>
        </geometry>
      </collision>
      <visual name="wheel_left_visual">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.065" length="0.046"/>
        </geometry>
        <material name="black"/>
      </visual>
    </link>

    <!-- Right Wheel Link -->
    <link name="wheel_right_link">
      <collision name="wheel_right_collision">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.065" length="0.046"/>
        </geometry>
      </collision>
      <visual name="wheel_right_visual">
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.065" length="0.046"/>
        </geometry>
        <material name="black"/>
      </visual>
    </link>

    <!-- Joint definitions -->

    <joint name="base_joint" type="fixed">
      <parent link="base_link"/>
      <child link="chassis"/>
      <origin xyz="0 0 0.001" rpy="0 0 0"/>
    </joint>

    <!--
      IMU mount (interpreted from the user's measurement):
      x = +0.0045 m  : robot front direction
      y = +0.0025 m  : robot left direction
      z = +0.1350 m  : robot up direction

      IMU axis mounting:
      imu x -> robot right
      imu y -> robot front
      imu z -> robot up

      This is a yaw rotation of -90 deg about Z from base_link to imu_link.
    -->
    <joint name="imu_joint" type="fixed">
      <parent link="base_link"/>
      <child link="imu_link"/>
      <origin xyz="0.0045 0.0025 0.135" rpy="0 0 -1.57079632679"/>
    </joint>

    <joint name="wheel_left_joint" type="continuous">
      <parent link="chassis"/>
      <child link="wheel_left_link"/>
      <origin xyz="0 0.1 0.065" rpy="-1.57 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>

    <joint name="wheel_right_joint" type="continuous">
      <parent link="chassis"/>
      <child link="wheel_right_link"/>
      <origin xyz="0 -0.1 0.065" rpy="1.57 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>

    <joint name="lidar_joint" type="fixed">
      <parent link="chassis"/>
      <child link="laser"/>
      <origin xyz="0.0 0.0 0.225" rpy="3.14 0 -3.14"/>
      <!-- <axis xyz="0 1 0"/> -->
    </joint>

    <joint name="lidar1_joint" type="fixed">
      <parent link="chassis"/>
      <child link="lidar1_link"/>
      <origin xyz="0.26 0.0 0.225" rpy="3.14 0 -3.14"/>
      <!-- <axis xyz="0 1 0"/> -->
    </joint>

    <joint name="lidar2_joint" type="fixed">
      <parent link="chassis"/>
      <child link="lidar2_link"/>
      <origin xyz="-0.26 -0.0 0.225" rpy="3.14 0 0"/>
      <!-- <axis xyz="0 1 0"/> -->
    </joint>


  </robot>